# Security
SESSION_MIDDLEWARE_SECRET_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-long-random-secret

# Database
DATABASE_URL=postgresql://ai_caller_user:PASSWORD@localhost:5432/ai_caller

# ── Streaming voice engine (production path) ────────────────────────────
# Pipeline selection: auto | streaming | legacy
#   auto      → streaming when DEEPGRAM_API_KEY + an LLM key are present,
#               otherwise the local (whisper/ollama/piper) legacy pipeline
VOICE_PIPELINE=auto

# Deepgram: streaming STT (Nova-3) AND Aura TTS with one key.
# Free $200 signup credit at https://console.deepgram.com/signup
DEEPGRAM_API_KEY=replace-with-provider-key

# LLM — any OpenAI-compatible endpoint. Groq free tier is the recommended
# low-latency default (https://console.groq.com). To use OpenAI instead:
#   LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
GROQ_API_KEY=replace-with-provider-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# TTS: deepgram (Aura, default — same key as STT) or elevenlabs
TTS_PROVIDER=deepgram
TTS_VOICE=aura-2-thalia-en
ELEVENLABS_API_KEY=replace-with-provider-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# STT tuning: nova-3 + "multi" enables code-switching (English + others).
STT_MODEL=nova-3
STT_LANGUAGE=multi
# Silence (ms) before the recognizer finalizes a user turn. Lower = snappier
# turn-taking, higher = fewer mid-sentence cutoffs. 300 is a good default.
ENDPOINTING_MS=300

# Barge-in: transcript (interrupt on real words — echo-safe, default)
#           or vad (interrupt on any speech energy — fastest)
BARGE_IN_ENABLED=true
BARGE_IN_MODE=transcript

# Call transfers: human escalation target (E.164). PUBLIC_BASE_URL enables
# the warm-transfer whisper (AI summary played to staff before bridging).
TRANSFER_NUMBER=
PUBLIC_BASE_URL=

# Skip auto-starting the knowledge_rag sidecar (cloud-only deploys)
RAG_AUTOSTART=true

# ── Legacy local pipeline (offline fallback) ────────────────────────────
LLM_EC2_KEY=replace-with-provider-key
STT_MODEL_SIZE=tiny.en
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4

# Logging
LOG_FILE=response_times.log
PRINT_INFO=True
PRINT_ERROR=True
PRINT_WARNING=True

# Email notifications (optional)
SENDER_EMAIL=notifications@example.com
EMAIL_PASSWORD=replace-with-app-password

# Speech timing
TIMING=1
TIMING_PATH=speech_timing.csv

# Cache directories
HF_HOME=d:\AIColdCaller\.cache\huggingface
HF_HUB_CACHE=d:\AIColdCaller\.cache\huggingface
TRANSFORMERS_CACHE=d:\AIColdCaller\.cache\huggingface
TORCH_HOME=d:\AIColdCaller\.cache\torch

# Twilio Configuration
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number

MODEL_ENDPOINT_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5vl:7b
MODEL_API_KEY=ollama
MODEL_REQUEST_TIMEOUT=180
# RAG_BUSINESS_ID: the business_id used when ingesting knowledge for this
# restaurant.  If blank, the agent auto-derives it from the restaurant name.
RAG_BUSINESS_ID=
TRIAL_QUOTA=100
PRO_QUOTA=1000
# Billing settings
PAYMENT_ACCOUNT_NAME=
PAYMENT_ACCOUNT_NUMBER=
MONTHLY_PRICE=5000.0

# SIP Configuration
SIP_ENABLED=false
SIP_STREAM_SAMPLE_RATE=16000



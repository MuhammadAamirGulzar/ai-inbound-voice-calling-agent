# Security
SESSION_MIDDLEWARE_SECRET_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-long-random-secret

# Database
DATABASE_URL=postgresql://ai_caller_user:PASSWORD@localhost:5432/ai_caller

# LLM and speech providers
LLM_EC2_KEY=replace-with-provider-key
ELEVENLABS_API_KEY=replace-with-provider-key
DEEPGRAM_API_KEY=replace-with-provider-key
STT_MODEL_SIZE=tiny.en
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4

# Logging
LOG_FILE=response_times.log
PRINT_INFO=True
PRINT_ERROR=True
PRINT_WARNING=True

# Email notifications (optional)
SENDER_EMAIL=notifications@example.com
EMAIL_PASSWORD=replace-with-app-password

# Speech timing
TIMING=1
TIMING_PATH=speech_timing.csv

# Cache directories
HF_HOME=d:\AIColdCaller\.cache\huggingface
HF_HUB_CACHE=d:\AIColdCaller\.cache\huggingface
TRANSFORMERS_CACHE=d:\AIColdCaller\.cache\huggingface
TORCH_HOME=d:\AIColdCaller\.cache\torch

# Twilio Configuration
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number

MODEL_ENDPOINT_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5vl:7b
MODEL_API_KEY=ollama
MODEL_REQUEST_TIMEOUT=180
# RAG_BUSINESS_ID: the business_id used when ingesting knowledge for this
# restaurant.  If blank, the agent auto-derives it from the restaurant name.
RAG_BUSINESS_ID=
TRIAL_QUOTA=100
PRO_QUOTA=1000
# Billing settings
PAYMENT_ACCOUNT_NAME=
PAYMENT_ACCOUNT_NUMBER=
MONTHLY_PRICE=5000.0

# SIP Configuration
SIP_ENABLED=false
SIP_STREAM_SAMPLE_RATE=16000



# Copy this file to .env and fill in MODEL_ENDPOINT_URL.

# --- Qwen2.5-VL via Ollama, running on a separate GPU machine, reached ---
# ---     through a tunnel (ngrok or similar) ---
#
# 1. On the GPU machine: install Ollama (https://ollama.com/download),
#    then `ollama pull qwen2.5vl:7b` (or :32b depending on VRAM).
# 2. Expose it publicly with a tunnel, e.g.:
#    ngrok http 11434
# 3. Paste that tunnel URL below, WITH a trailing /v1 (Ollama's
#    OpenAI-compatible endpoint lives at <url>/v1/chat/completions).
MODEL_ENDPOINT_URL=https://replace-with-tunnel-endpoint/v1

# Must exactly match the tag shown by `ollama list` on the GPU machine.
MODEL_NAME=qwen2.5vl-16k

# Ollama ignores this value, but the OpenAI-style API requires *some*
# non-empty string in the Authorization header. No need to change it.
MODEL_API_KEY=ollama

# Per-request timeout (seconds). Kept generous for slow tunnel + local-GPU
# round trips, especially on scanned-image pages.
MODEL_REQUEST_TIMEOUT=300

# --- Embeddings (local, CPU, no API key, no network call — see app/config.py) ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Silences ChromaDB's anonymous usage-telemetry prompt.
ANONYMIZED_TELEMETRY=False

# Cache directories
HF_HOME=d:\AIColdCaller\.cache\huggingface
HF_HUB_CACHE=d:\AIColdCaller\.cache\huggingface
TRANSFORMERS_CACHE=d:\AIColdCaller\.cache\huggingface
TORCH_HOME=d:\AIColdCaller\.cache\torch